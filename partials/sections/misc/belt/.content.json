{
    "name": "Belt",
    "enableConfig": true,
    "priority": 10,

    "loaders": {
        "children": {
            "loader": "pages",
            "params": {
                "basePageId": "{{?: config.basePageSlug '' page.id}}",
                "basePageSlug": "{{config.basePageSlug}}",
                "sort": "{{?? config.sort '-publishDate'}}",
                "allResults": "{{?: (eq config.limit 0) 'true' 'false'}}",
                "withContent": true,
                "deep": "{{?: (equals config.searchType 'all') 'true' 'false'}}",
                "limit": "{{?? config.limit 1000}}",
                "filter": "{{mode}}.forms.general.hideInLists != true"
            }
        }
    }
}
