{{let .
      localColumnsClass=(?? columnsClass 'col-12 col-sm-6 col-xl-3')
      localColumnSetting=(?? columnSetting 'four')
}}

<div class="row justify-content-center text-center">

    {{> tile columnsClass=localColumnsClass quoteEdit='testimonial1QuoteSvg' quoteSvg=testimonial1QuoteSvg textEdit='testimonial1Text innerHTML' text=(?? testimonial1Text "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam eu sem tempor, varius quam at, luctus dui.") imageSrc=(?? testimonial1ImageSrc '/assets/img/empty.png') imageAlt=testimonial1ImageAlt imageEdit='testimonial1ImageSrc @src, testimonial1ImageAlt @alt' authorEdit='testimonial1Author innerHTML' author=(?? testimonial1Author "John Doe") roleEdit='testimonial1Role innerHTML' role=(?? testimonial1Role "Company Inc.")}}

    {{#unless (eq localColumnSetting 'one')}}
        {{> tile columnsClass=localColumnsClass quoteEdit='testimonial2QuoteSvg' quoteSvg=testimonial2QuoteSvg textEdit='testimonial2Text innerHTML' text=(?? testimonial2Text "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam eu sem tempor, varius quam at, luctus dui.") imageSrc=(?? testimonial2ImageSrc '/assets/img/empty.png') imageAlt=testimonial2ImageAlt imageEdit='testimonial2ImageSrc @src, testimonial2ImageAlt @alt' authorEdit='testimonial2Author innerHTML' author=(?? testimonial2Author "Jane Doe") roleEdit='testimonial2Role innerHTML' role=(?? testimonial2Role "Company Inc.")}}
    {{/unless}}

    {{#if (eq localColumnSetting 'three')}}
        {{> tile columnsClass=localColumnsClass quoteEdit='testimonial3QuoteSvg' quoteSvg=testimonial3QuoteSvg textEdit='testimonial3Text innerHTML' text=(?? testimonial3Text "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam eu sem tempor, varius quam at, luctus dui.") imageSrc=(?? testimonial3ImageSrc '/assets/img/empty.png') imageAlt=testimonial3ImageAlt imageEdit='testimonial3ImageSrc @src, testimonial3ImageAlt @alt' authorEdit='testimonial3Author innerHTML' author=(?? testimonial3Author "John Doe") roleEdit='testimonial3Role innerHTML' role=(?? testimonial3Role "Company Inc.")}}
    {{/if}}

    {{#if (eq localColumnSetting 'four')}}
        {{> tile columnsClass=localColumnsClass quoteEdit='testimonial3QuoteSvg' quoteSvg=testimonial3QuoteSvg textEdit='testimonial3Text innerHTML' text=(?? testimonial3Text "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam eu sem tempor, varius quam at, luctus dui.") imageSrc=(?? testimonial3ImageSrc '/assets/img/empty.png') imageAlt=testimonial3ImageAlt imageEdit='testimonial3ImageSrc @src, testimonial3ImageAlt @alt' authorEdit='testimonial3Author innerHTML' author=(?? testimonial3Author "John Doe") roleEdit='testimonial3Role innerHTML' role=(?? testimonial3Role "Company Inc.")}}
        {{> tile columnsClass=localColumnsClass quoteEdit='testimonial4QuoteSvg' quoteSvg=testimonial4QuoteSvg textEdit='testimonial4Text innerHTML' text=(?? testimonial4Text "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam eu sem tempor, varius quam at, luctus dui.") imageSrc=(?? testimonial4ImageSrc '/assets/img/empty.png') imageAlt=testimonial4ImageAlt imageEdit='testimonial4ImageSrc @src, testimonial4ImageAlt @alt' authorEdit='testimonial4Author innerHTML' author=(?? testimonial4Author "Jane Doe") roleEdit='testimonial4Role innerHTML' role=(?? testimonial4Role "Company Inc.")}}
    {{/if}}
</div>



{{#*inline "tile"}}
    <div class="{{localColumnsClass}} mb-5">
        <div class="testimonial {{#unless useAltBackground}}altBackgroundColor-bg{{/unless}}" style="box-shadow:none">
            <div>

                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    xml:space="preserve"
                    viewBox="0 0 33 25"
                    width="42" height="42"
                    color="var(--theme-tertiaryColor)"
                    fill="var(--theme-tertiaryColor)"
                ><g><path d="M18.006,6.538c0-1.973,0.662-3.554,1.988-4.743c1.326-1.19,2.977-1.785,4.947-1.785c2.517,0,4.488,0.799,5.916,2.397C32.285,4.004,33,6.13,33,8.782c0,2.719-0.424,5.032-1.275,6.936c-0.85,1.903-1.869,3.483-3.061,4.743c-1.188,1.258-2.43,2.244-3.723,2.958c-1.291,0.714-2.413,1.239-3.365,1.581l-3.265-5.508c1.36-0.545,2.517-1.412,3.468-2.602c0.953-1.19,1.496-2.465,1.633-3.824c-1.359,0-2.602-0.597-3.724-1.786C18.566,10.09,18.006,8.509,18.006,6.538z M0.359,6.538c0-1.973,0.663-3.554,1.989-4.743C3.674,0.604,5.324,0.01,7.295,0.01c2.518,0,4.488,0.799,5.916,2.397c1.429,1.597,2.143,3.723,2.143,6.375c0,2.719-0.424,5.032-1.275,6.936c-0.85,1.903-1.869,3.483-3.06,4.743c-1.188,1.258-2.431,2.244-3.724,2.958C6.004,24.133,4.883,24.658,3.93,25l-3.264-5.508c1.36-0.545,2.516-1.412,3.467-2.602c0.953-1.19,1.497-2.465,1.633-3.824c-1.359,0-2.602-0.597-3.723-1.786C0.92,10.09,0.359,8.509,0.359,6.538z"></path></g></svg>
            </div>
            <p class="mt-3" edit="{{textEdit}}">{{{text}}}</p>
            <img
                    src="{{imageSrc}}"
                    data-image-hint="width=512"
                    alt="{{imageAlt}}"
                    width="100"
                    class="img-fluid rounded-circle mb-3 p-0 img-thumbnail shadow ratio-1-1"
                    loading="lazy"
                    edit="{{imageEdit}}"
            >
            <h4 class="mb-0" edit="{{authorEdit}}">{{{author}}}</h4><span class="small text-uppercase text-muted" edit="{{roleEdit}}">{{{role}}}</span>
        </div>
    </div>
{{/inline}}
