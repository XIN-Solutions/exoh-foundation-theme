<form class="config-form"
      x-data="componentDialog({
            defaultConfig: {
                compact: false,
                hideTitle: false,
                hideSubtitle: false,
                hideImage: false,
                hideButton: false,
                spacing: 'comfortable',
                noTopSpacing: false,
                noBottomSpacing: false,
                overlayColour: '#000000',
                overlayOpacity: 0.7,
                hideOverlay: false,
                backgroundImage: '',
                backgoundVideo: '',
                setHeroSeparators: false,
                reduceSeparator: false,
                separatorDifferentTopBottom: false,
                separatorPairBase: '',
                separatorTopId: '',
                separatorBottomId: ''
            }
      })"
      @set="setConfig"
      @get="getConfig"
>

    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#hero-banner" role="tab">Hero Banner</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#hero-show-hide" role="tab">Show/Hide</a>
        </li>
        {{> common/dialogs/basic_nav }}
    </ul>

    <div class="tab-content tab-content--withBorder">
        <div class="tab-pane fade show active" id="hero-banner" role="tabpanel">
            <div class="mb-3">
                <div class="mb-3">
                    <div class="form-check">
                        <label class="form-check-label">
                            <input class="form-check-input" type="checkbox" x-model="config.compact">
                            Is a compact banner.
                        </label>
                    </div>
                    <p class="form-text text-muted mb-0 small">Uses less vertical padding so the hero takes up less space on the page.</p>
                </div>

                <div class="form-check mt-4 mb-2">
                    <label class="form-check-label">
                        <input class="form-check-input" type="checkbox" x-model="config.hideOverlay">
                        Hide tint 
                    </label>
                </div>
                <p class="form-text text-muted small mb-2">When off, a semi-transparent layer sits over the background to improve text contrast.</p>

                <div x-show="!config.hideOverlay" class="p-3 mb-3 bg-light border rounded">
                    <div class="mb-3 d-flex align-items-center gap-2">
                        <label for="overlayColour" class="form-label mb-0">Tint Colour</label>
                        <input 
                            type="color" 
                            class="form-control form-control-color"
                            id="overlayColour"
                            x-model="config.overlayColour"
                            title="Choose tint color"
                        >
                    </div>
                    <div class="mb-0 d-flex align-items-center gap-2">
                        <label for="overlayOpacity" class="form-label mb-0">Tint&nbsp;Opacity</label>
                        <input 
                            type="range" 
                            class="form-range flex-fill"
                            id="overlayOpacity"
                            min="0"
                            max="1"
                            step="0.01"
                            x-model="config.overlayOpacity"
                        >
                    </div>
                </div>

                {{!-- Background image selector --}}
                {{> common/dialogs/image field="config.backgroundImage" label="Background image" hint="Shown behind the hero text. Pick a wide image (for example 1920px) for best results. If video also configured, this will be the poster." }}

                {{!-- Background video selector --}}
                {{> common/dialogs/video field="config.backgroundVideo" label="Background Video" hint="Shown behind the hero text. Pick a wide video (for example 1920px) for best results." }}


                {{> common/shapes/hero_separator_names }}
                <div x-data="heroSeparatorControls()">
                    <div class="form-check mt-4 mb-2">
                        <label class="form-check-label">
                            <input class="form-check-input" type="checkbox" x-model="config.setHeroSeparators">
                            Set Hero Separators
                        </label>
                    </div>
                    <p class="form-text text-muted small mb-2">Decorative SVG edges between the hero and the rest of the page. Leave off to keep the default shapes.</p>

                    <div x-show="config.setHeroSeparators" class="p-3 mb-3 bg-light border rounded">
                        <div class="form-check mb-2">
                            <label class="form-check-label">
                                <input class="form-check-input" type="checkbox" x-model="config.separatorDifferentTopBottom" @change="onDifferentToggle()">
                                The top and bottom have different separators
                            </label>
                        </div>
                        <p class="form-text text-muted small mb-3">Turn on to pick the top and bottom shapes independently; leave off to choose one matched pair.</p>


                        <div class="form-check mb-2">
                            <label class="form-check-label">
                                <input class="form-check-input" type="checkbox" x-model="config.reduceSeparator">
                                Reduce scale of separator(s)
                            </label>
                        </div>
                        <p class="form-text text-muted small mb-3">Turn on to pick the top and bottom shapes independently; leave off to choose one matched pair.</p>

                        <div x-show="!config.separatorDifferentTopBottom" class="mb-0">
                            <label class="form-label">Separator pair</label>
                            {{> common/dialogs/svg_preview_select
                                includeStyle=true
                                class=""
                                model="config.separatorPairBase"
                                onChange="onPairBaseChange()"
                                mode="pair"
                                options=topBottomPairBaseIds
                                labels=labels
                            }}
                            <p class="form-text text-muted mb-0 small">One style for both edges: the top uses the “top” variant and the bottom the “bottom” variant of the same design.</p>
                        </div>

                        <div x-show="config.separatorDifferentTopBottom" class="mb-0">
                            <label class="form-label">Top separator</label>
                            {{> common/dialogs/svg_preview_select
                                class="mb-2"
                                model="config.separatorTopId"
                                mode="single"
                                options=topBorderIds
                                labels=labels
                                noneLabel="No separator"
                            }}
                            <p class="form-text text-muted small mb-3">Shape along the upper edge of the hero (where it meets the content above). Choose “No separator” to remove it.</p>
                            <label class="form-label">Bottom separator</label>
                            {{> common/dialogs/svg_preview_select
                                class="mb-2"
                                model="config.separatorBottomId"
                                mode="single"
                                options=bottomBorderIds
                                labels=labels
                                noneLabel="No separator"
                            }}
                            <p class="form-text text-muted mb-0 small">Shape along the lower edge of the hero (where it meets the section below).</p>
                        </div>
                    </div>
                </div>
            </div>

            
        </div>

        <div class="tab-pane fade" id="hero-show-hide" role="tabpanel">
            <div class="mb-3">
                <p class="form-text text-muted small mb-3">Toggle which optional blocks render in this hero.</p>
                <div class="p-3 mb-3 bg-light border rounded">
                    <div class="mb-3">
                        <div class="form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" type="checkbox" x-model="config.hideTitle">
                                Hide title
                            </label>
                        </div>
                        <p class="form-text text-muted mb-0 small">Hides the main heading (the primary hero title).</p>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" type="checkbox" x-model="config.hideSubtitle">
                                Hide subtitle
                            </label>
                        </div>
                        <p class="form-text text-muted mb-0 small">Hides the secondary heading under the main title.</p>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" type="checkbox" x-model="config.hideImage">
                                Hide image
                            </label>
                        </div>
                        <p class="form-text text-muted mb-0 small">When the hero template includes an extra content image (not the background), this hides it.</p>
                    </div>
                    <div class="mb-0">
                        <div class="form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" type="checkbox" x-model="config.hideButton">
                                Hide button
                            </label>
                        </div>
                        <p class="form-text text-muted mb-0 small">Hides the call-to-action link or button area.</p>
                    </div>
                </div>
            </div>
        </div>

        {{> common/dialogs/basic_content hideAlternateBackground=true }}
    </div>

</form>
