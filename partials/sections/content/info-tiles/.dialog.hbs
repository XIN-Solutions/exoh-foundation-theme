<form id="infoTilesConfigForm" class="config-form"
      x-data="componentDialog({
            defaultConfig: {
                columns: 'three',
                imagePosition: 'top',
                hideTitle: false,
                hideCta: false,
                centerTileText: false,
                useAltBackground: false,
                spacing: 'comfortable',
                noTopSpacing: false,
                noBottomSpacing: false
            }
      })"
      @set="setConfig"
      @get="getConfig"
>

    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#info-tiles-component" role="tab">Component</a>
        </li>
        {{> common/dialogs/basic_nav }}
    </ul>

    <div class="tab-content tab-content--withBorder">
        <div class="tab-pane fade show active" id="info-tiles-component" role="tabpanel">
            <div class="mb-3">
                <label class="form-label">Columns</label>
                <select class="form-select" x-model="config.columns">
                    <option value="three">Three columns</option>
                    <option value="four">Four columns</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Image position</label>
                <div class="btn-group w-100" role="group" aria-label="Image position">
                    <input type="radio" class="btn-check" name="infoTilesImagePosition" id="info-tiles-image-top" value="top" x-model="config.imagePosition">
                    <label class="btn btn-outline-primary" for="info-tiles-image-top">Above text</label>

                    <input type="radio" class="btn-check" name="infoTilesImagePosition" id="info-tiles-image-below" value="below" x-model="config.imagePosition">
                    <label class="btn btn-outline-primary" for="info-tiles-image-below">Below text</label>
                </div>
                <p class="form-text text-muted mb-0 small">Place the tile image above or below the title and description.</p>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <label class="form-check-label">
                        <input class="form-check-input" type="checkbox" x-model="config.hideTitle">
                        Hide title
                    </label>
                </div>
                <div class="form-check">
                    <label class="form-check-label">
                        <input class="form-check-input" type="checkbox" x-model="config.centerTileText">
                        Center the text
                    </label>
                </div>
                <div class="form-check">
                    <label class="form-check-label">
                        <input class="form-check-input" type="checkbox" x-model="config.hideCta">
                        Hide call to action
                    </label>
                </div>
            </div>
        </div>

        {{> common/dialogs/basic_content }}
    </div>

</form>
