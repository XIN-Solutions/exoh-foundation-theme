<form id="freeformColumnsConfigForm" class="config-form"
      x-data="componentDialog({
            defaultConfig: {
                columns: 'four',
                useAltBackground: false,
                spacing: 'comfortable',
                noTopSpacing: false,
                noBottomSpacing: false
            }
      })"
      @set="setConfig"
      @get="getConfig"
>
    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#freeform-columns-component" role="tab">Component</a>
        </li>
        {{> common/dialogs/basic_nav }}
    </ul>

    <div class="tab-content tab-content--withBorder">
        <div class="tab-pane fade show active" id="freeform-columns-component" role="tabpanel">
            <div class="mb-3">
                <label class="form-label">Columns</label>
                <select class="form-select" x-model="config.columns">
                    <option value="one">1 column</option>
                    <option value="two">2 columns</option>
                    <option value="three">3 columns</option>
                    <option value="four">4 columns</option>
                    <option value="five">5 columns</option>
                    <option value="six">6 columns</option>
                </select>
            </div>
        </div>

        {{> common/dialogs/basic_content }}
    </div>
</form>
