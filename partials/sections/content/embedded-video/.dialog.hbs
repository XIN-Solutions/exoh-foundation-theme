<form class="config-form"
      x-data="componentDialog({
            defaultConfig: {
                videoType: 'youtube',
                video: '',
                columnSize: '8',
                useAltBackground: false,
                spacing: 'comfortable',
                noTopSpacing: false,
                noBottomSpacing: false
            },
            beforeSetConfig: (c) => {
                const videoType = c.videoType || 'youtube';
                const extracted = window.__exohExtractEmbeddedVideoId?.(videoType, c.video);
                return { ...c, videoType, video: extracted || (c.video || '').trim() };
            },
            beforeGetConfig: (c) => {
                const videoType = c.videoType || 'youtube';
                const extracted = window.__exohExtractEmbeddedVideoId?.(videoType, c.video);
                return { ...c, videoType, video: extracted || (c.video || '').trim() };
            }
      })"
      @set="setConfig"
      @get="getConfig"
>

    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#embedded-video-video" role="tab">Video</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#embedded-video-layout" role="tab">Layout</a>
        </li>
        {{> common/dialogs/basic_nav }}
    </ul>

    <div class="tab-content tab-content--withBorder">
        <div class="tab-pane fade show active" id="embedded-video-video" role="tabpanel">
            <div class="mb-3">
                <label class="form-label">Video type</label>
                <select class="form-select" x-model="config.videoType">
                    <option value="youtube">YouTube</option>
                    <option value="vimeo">Vimeo</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Video</label>
                <input type="text" class="form-control" x-model="config.video" placeholder="Paste a URL or enter the ID">
                <p class="form-text text-muted mb-0 small">Paste the share URL (or embed URL) or just the video ID. We’ll store the extracted ID.</p>
            </div>
        </div>

        <div class="tab-pane fade" id="embedded-video-layout" role="tabpanel">
            <div class="mb-3">
                <label class="form-label">Column size</label>
                <select class="form-select" x-model="config.columnSize">
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="5">5</option>
                    <option value="6">6</option>
                    <option value="7">7</option>
                    <option value="8">8</option>
                    <option value="9">9</option>
                    <option value="10">10</option>
                    <option value="11">11</option>
                    <option value="12">12</option>
                </select>
            </div>
        </div>

        {{> common/dialogs/basic_content }}
    </div>

</form>
