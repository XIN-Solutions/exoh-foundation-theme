<section
    class="
        {{?: config.useAltBackground 'bg--alternate' ''}}
        spacing--{{?? config.spacing 'comfortable'}}
        {{?: config.noTopSpacing 'spacing--no-top' ''}}
        {{?: config.noBottomSpacing 'spacing--no-bottom' ''}}
    "
    no-edit="children"
    allowadd="no"
    allowdelete="no"
>
    <div class="container">
        <div class="row">
            <div class="col-md-{{?? config.columnSize '12'}} col-sm-12 mx-auto">
                {{#if config.video}}
                    <div class="ratio ratio-16x9">
                        {{#if (eq (?? config.videoType 'youtube') 'vimeo')}}
                            <iframe
                                src="https://player.vimeo.com/video/{{config.video}}"
                                title="Vimeo video"
                                allow="autoplay; fullscreen; picture-in-picture"
                                allowfullscreen
                                loading="lazy"
                            ></iframe>
                        {{else}}
                            <iframe
                                src="https://www.youtube-nocookie.com/embed/{{config.video}}"
                                title="YouTube video"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                allowfullscreen
                                loading="lazy"
                                referrerpolicy="strict-origin-when-cross-origin"
                            ></iframe>
                        {{/if}}
                    </div>
                {{else}}
                    <div class="alert alert-warning mb-0" role="alert">
                        Please configure a video.
                    </div>
                {{/if}}
            </div>
        </div>
    </div>
</section>
