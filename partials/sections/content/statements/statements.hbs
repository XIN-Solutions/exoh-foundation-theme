{{let .
      isLeft=(eq (?? config.imagePosition "left") "left")
      isRight=(eq (?? config.imagePosition "left") "right")
}}

<section
    class="
        features-5 bg-alternate
        {{?: config.useAltBackground 'bg--alternate' ''}}
        spacing--{{?? config.spacing 'comfortable'}}
        {{?: config.noTopSpacing 'spacing--no-top' ''}}
        {{?: config.noBottomSpacing 'spacing--no-bottom' ''}}
    "
    no-edit="children"
    allowadd="no"
    allowdelete="no"
>
    <div class="container">
        <div class="row align-items-center">
            {{#if isLeft}}
                {{> imageCol}}
            {{/if}}

            <div class="col-12 col-lg-6 col-xl-5 ms-sm-auto pt-5 pt-lg-0">
                {{#unless config.hideTitle}}
                    <h2 class="h3" edit="title innerHTML">{{{?? title "Lorem ipsum dolor sit amet."}}}</h2>
                {{/unless}}

                <div class="row pt-4 pt-xl-5">
                    <div class="col-12 col-sm-6 col-xl-5">
                        <h3 class="h5"><strong edit="statement1Title">{{{?? statement1Title "Cras felis nunc"}}}</strong></h3>
                        <p class="fw-light" edit="statement1Description">{{{?? statement1Description "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Maecenas cursus in lectus ut dignissim."}}}</p>
                    </div>
                    <div class="col-12 col-sm-6 col-xl-5 m-auto pt-3 pt-sm-0">
                        <h3 class="h5"><strong edit="statement2Title">{{{?? statement2Title "Cras felis nunc"}}}</strong></h3>
                        <p class="fw-light" edit="statement2Description">{{{?? statement2Description "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Maecenas cursus in lectus ut dignissim."}}}</p>
                    </div>
                </div>

                <div class="row pt-3">
                    <div class="col-12 col-sm-6 col-xl-5">
                        <h3 class="h5"><strong edit="statement3Title">{{{?? statement3Title "Cras felis nunc."}}}</strong></h3>
                        <p class="fw-light" edit="statement3Description">{{{?? statement3Description "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Maecenas cursus in lectus ut dignissim."}}}</p>
                    </div>
                    <div class="col-12 col-sm-6 col-xl-5 m-auto pt-3 pt-sm-0">
                        <h3 class="h5"><strong edit="statement4Title">{{{?? statement4Title "Cras felis nunc."}}}</strong></h3>
                        <p class="fw-light" edit="statement4Description">{{{?? statement4Description "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Maecenas cursus in lectus ut dignissim."}}}</p>
                    </div>
                </div>
            </div>

            {{#if isRight}}
                {{> imageCol}}
            {{/if}}
        </div>
    </div>
</section>

{{#*inline "imageCol"}}
    <div class="col-12 col-md-8 col-lg-6 m-md-auto">
        <img
            {{#if imageId}} id="{{imageId}}" {{/if}}
            src="{{?? imageSrc '/assets/img/empty.png'}}"
            alt="{{imageAlt}}"
            loading="lazy"
            class="{{?? imageClass 'img-fluid w-100'}}"
            edit="imageSrc @src, imageAlt @alt, imageClass @class, imageId @id"
            data-image-hint="width=768"
        >
    </div>
{{/inline}}
