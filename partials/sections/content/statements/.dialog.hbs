<form id="featureConfigForm" class="config-form"
      x-data="componentDialog({
            defaultConfig: {
                imagePosition: 'left',
                hideTitle: false,
                useAltBackground: false,
                spacing: 'comfortable',
                noTopSpacing: false,
                noBottomSpacing: false
            }
      })"
      @set="setConfig"
      @get="getConfig"
>

    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#statements-component" role="tab">Component</a>
        </li>
        {{> common/dialogs/basic_nav }}
    </ul>

    <div class="tab-content tab-content--withBorder">
        <div class="tab-pane fade show active" id="statements-component" role="tabpanel">
            <div class="mb-3">
                <div class="form-check">
                    <label class="form-check-label">
                        <input class="form-check-input" type="checkbox" x-model="config.hideTitle">
                        Hide title
                    </label>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Image Position</label>
                <div class="btn-group w-100" role="group" aria-label="Image position">
                    <input type="radio" class="btn-check" name="imagePosition" id="statements-image-left" value="left" x-model="config.imagePosition">
                    <label class="btn btn-outline-primary" for="statements-image-left">Left</label>

                    <input type="radio" class="btn-check" name="imagePosition" id="statements-image-right" value="right" x-model="config.imagePosition">
                    <label class="btn btn-outline-primary" for="statements-image-right">Right</label>
                </div>
            </div>
        </div>

        {{> common/dialogs/basic_content }}
    </div>

</form>
