{
    "name": "EX:OH Foundation Theme",
    "version": "1.0",
    "env": {
        "default": {
            "url": "http://localhost:9999"
        },
        "production": {
            "url": "https://vvvebjs-hbs-theme.exoh.cloud"
        },
        "emy_prod": {
            "url": "https://classic-theme.cms.enrolmy.com"
        }
    },
    "aspects": [
        {
            "name": "styles",
            "title": "Theme",
            "pageTypes": [
                "site"
            ],
            "template": "pages/aspects/styles.html",
            "defaults": {
                "themeStylingEnabled": "yes",
                "darkMode": "no",
                "primaryColor": "#007bff",
                "secondaryColor": "#6c757d",
                "tertiaryColor": "#28a745",
                "backgroundColor": "#ffffff",
                "altBackgroundColor": "#f8f9fa",
                "h1Color": "#212529",
                "h1FontFamily": "'Open Sans', sans-serif",
                "h1FontWeight": "700",
                "h1FontSize": "48px",
                "h2Color": "#495057",
                "h2FontFamily": "'Open Sans', sans-serif",
                "h2FontWeight": "600",
                "h2FontSize": "36px",
                "h3Color": "#6c757d",
                "h3FontFamily": "'Open Sans', sans-serif",
                "h3FontWeight": "600",
                "h3FontSize": "28px",
                "h4Color": "#6c757d",
                "h4FontFamily": "'Open Sans', sans-serif",
                "h4FontWeight": "500",
                "h4FontSize": "20px",
                "h5Color": "#6c757d",
                "h5FontFamily": "'Open Sans', sans-serif",
                "h5FontWeight": "500",
                "h5FontSize": "16px",
                "paragraphColor": "#212529",
                "paragraphFontFamily": "'Open Sans', sans-serif",
                "paragraphFontWeight": "400",
                "paragraphFontSize": "16px",
                "googleFonts": "[]",
                "cardBorderRadius": "default",
                "buttonBorderRadius": "default",
                "imageBorderRadius": "default",
                "cardShadow": "sm",
                "buttonColorSource": "tertiary",
                "buttonColorCustom": "",
                "menuStylingEnabled": "no",
                "menuItemColor": "",
                "menuCtaColor": "",
                "menuCtaTextColor": "",
                "menuFontFamily": "",
                "menuFontSize": "",
                "menuFontWeight": ""
            }
        }
    ],
    "editor": {
        "javascripts": [
            "editing/component-sections.js",
            "editing/dialog-behaviours.js",
            "editing/vvveb.js"
        ]
    },
    "files": {
        "layouts": [
            "content_block.hbs",
            "main.hbs"
        ],
        "pages": [
            "content_page.hbs",
            "editing/blocks.hbs",
            "editing/empty.hbs",
            "site.hbs",
            "theme_styles_css.hbs"
        ],
        "data": [
            "site.jsonc"
        ],
        "partials": [
            "common/dialogs/basic_content.hbs",
            "common/dialogs/basic_nav.hbs",
            "common/dialogs/html_preview_select.hbs",
            "common/dialogs/image.hbs",
            "common/dialogs/svg_preview_select.hbs",
            "common/dialogs/video.hbs",
            "common/shapes/hero_separator_names.hbs",
            "common/shapes/hero_separator_names.json",
            "common/shapes/hero_separator_svgs.hbs",
            "nav/footer.hbs",
            "nav/header.hbs",
            "sections/content/.content.json",
            "sections/content/column-showcase/.content.json",
            "sections/content/column-showcase/.dialog.hbs",
            "sections/content/column-showcase/column-showcase.hbs",
            "sections/content/column-showcase/disabled/borderless.hbs",
            "sections/content/column-showcase/disabled/flat.hbs",
            "sections/content/column-showcase/disabled/spacious.hbs",
            "sections/content/column-showcase/standard.hbs",
            "sections/content/embedded-video/.content.json",
