            "sections/content/icon-banner/icon-banner.hbs",
            "sections/content/icons-and-image/.content.json",
            "sections/content/icons-and-image/.dialog.hbs",
            "sections/content/icons-and-image/icons-and-image.hbs",
            "sections/content/info-tiles/.content.json",
            "sections/content/info-tiles/.dialog.hbs",
            "sections/content/info-tiles/info-tiles.hbs",
            "sections/content/markdown-text/.content.json",
            "sections/content/markdown-text/.dialog.hbs",
