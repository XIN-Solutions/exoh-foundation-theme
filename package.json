{
    "name": "exoh-foundation-theme",
    "version": "1.0.0",
    "description": "Exoh CMS Foundation Theme (Vvveb-based)",
    "author": "Marnix Kok & Ziadin Givan",
    "license": "Apache-2.0",
    "main": "index.js",
    "scripts": {
        "build": "npm run sass-build && npm run update-metadata",
        "update-metadata": "node scripts/update-metadata.mjs",
        "sass-build": "sass assets/scss/style.bundle.scss assets/css/style.bundle.css --load-path=assets/scss --no-source-map --style=expanded",
        "sass:watch": "sass assets/scss/style.bundle.scss assets/css/style.bundle.css --load-path=assets/scss --watch --no-source-map --style=expanded",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "devDependencies": {
        "sass": "^1.71.1"
    }
}
